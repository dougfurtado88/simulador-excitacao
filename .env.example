# ══════════════════════════════════════════════════════
# Variáveis de ambiente — Simulador de Ensaios Dinâmicos
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o .env com valores reais
# ══════════════════════════════════════════════════════

# GitHub (usado pelo auto_sync.py e scripts de execução)
GITHUB_TOKEN=

# Servidor local
SERVER_PORT=8080
SERVER_HOST=localhost

# Diretório raiz do simulador (relativo à raiz do projeto)
SIMULATOR_DIR=Simulador
SIMULATOR_FILE=Simulador_Excitacao.html

# Python interpreter
PYTHON_BIN=C:/Users/dougl/AppData/Local/Programs/Python/Python312/python.exe
